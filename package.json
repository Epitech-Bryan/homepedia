{
  "name": "homepedia",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "HomePedia monorepo — React + Spring Boot",
  "workspaces": [
    "webapp"
  ],
  "overrides": {
    "@types/node": "^24.0.0"
  },
  "lint-staged": {
    "webapp/src/**/*.{ts,tsx}": [
      "pnpm -C webapp exec eslint --fix",
      "pnpm -C webapp exec prettier --write"
    ],
    "webapp/src/**/*.{css,json}": [
      "pnpm -C webapp exec prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "scripts": {
    "prepare": "husky"
  }
}
